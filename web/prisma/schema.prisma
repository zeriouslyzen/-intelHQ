// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String    @default("")
  displayName   String?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  roles         String    @default("user")
  preferences   Json      @default("{}")
  watchlists    Watchlist[]
  messages      Message[]
  threads       Thread[]  @relation("ThreadCreator")
  accounts      Account[]
  sessions      Session[]
  threadParticipants ThreadParticipant[]
  buddiesAsUser     BuddyList[]    @relation("BuddyListUser")
  buddiesAsBuddy    BuddyList[]    @relation("BuddyListBuddy")
  chatProfile       ChatProfile?
}

model ChatProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  status      String   @default("online")
  awayMessage String?
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BuddyList {
  id          String   @id @default(cuid())
  userId      String
  buddyUserId String
  createdAt   DateTime @default(now())

  user   User @relation("BuddyListUser", fields: [userId], references: [id], onDelete: Cascade)
  buddy  User @relation("BuddyListBuddy", fields: [buddyUserId], references: [id], onDelete: Cascade)

  @@unique([userId, buddyUserId])
}

model Instrument {
  id         String      @id @default(cuid())
  symbol     String      @unique
  name       String
  class      String
  regionId   String
  currency   String
  exchange   String?
  sector     String?
  tags       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  region     Region      @relation(fields: [regionId], references: [id])
  watchlists Watchlist[]
  messages   Message[]
}

model Region {
  id        String       @id @default(cuid())
  name      String
  code      String       @unique
  parentId  String?
  centroidLat Float
  centroidLon Float
  shapeKey  String?

  parent    Region?      @relation("RegionParent", fields: [parentId], references: [id])
  children  Region[]     @relation("RegionParent")
  instruments Instrument[]
}

model Event {
  id                 String      @id @default(cuid())
  kind               String
  title              String
  description        String?
  source             String
  url                String?
  time               DateTime
  impactLevel        String
  aiLabels           String?
  relatedInstrumentIds String?
  relatedRegionIds     String?
}

model Thread {
  id            String      @id @default(cuid())
  contextType   String
  contextInstrumentId String?
  contextRegionId     String?
  contextEventId      String?
  title         String
  createdAt     DateTime    @default(now())
  createdById   String
  isReadOnly    Boolean     @default(false)
  latestSummaryId String?

  createdBy     User        @relation("ThreadCreator", fields: [createdById], references: [id])
  messages      Message[]
  participants  ThreadParticipant[]
}

model ThreadParticipant {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  createdAt DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
}

model Message {
  id           String    @id @default(cuid())
  threadId     String
  authorId     String
  body         String
  createdAt    DateTime  @default(now())
  editedAt     DateTime?
  instrumentIds String?
  regionIds     String?
  eventIds      String?

  thread       Thread    @relation(fields: [threadId], references: [id])
  author       User      @relation(fields: [authorId], references: [id])
  instrument   Instrument? @relation(fields: [instrumentIds], references: [id])
}

model Watchlist {
  id           String        @id @default(cuid())
  name         String
  userId       String
  createdAt    DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id])
  instruments  Instrument[]
}

model Note {
  id            String    @id @default(cuid())
  body          String
  regionCode    String?
  instrumentId  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model LayoutConfig {
  id        String   @id @default(cuid())
  name      String
  config    String
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
