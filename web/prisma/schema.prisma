// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  displayName  String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  roles        String
  preferences  Json
  watchlists   Watchlist[]
  messages     Message[]
  threads      Thread[]         @relation("ThreadCreator")
}

model Instrument {
  id         String      @id @default(cuid())
  symbol     String      @unique
  name       String
  class      String
  regionId   String
  currency   String
  exchange   String?
  sector     String?
  tags       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  region     Region      @relation(fields: [regionId], references: [id])
  watchlists Watchlist[]
  messages   Message[]
}

model Region {
  id        String       @id @default(cuid())
  name      String
  code      String       @unique
  parentId  String?
  centroidLat Float
  centroidLon Float
  shapeKey  String?

  parent    Region?      @relation("RegionParent", fields: [parentId], references: [id])
  children  Region[]     @relation("RegionParent")
  instruments Instrument[]
}

model Event {
  id                 String      @id @default(cuid())
  kind               String
  title              String
  description        String?
  source             String
  url                String?
  time               DateTime
  impactLevel        String
  aiLabels           String?
  relatedInstrumentIds String?
  relatedRegionIds     String?
}

model Thread {
  id            String      @id @default(cuid())
  contextType   String
  contextInstrumentId String?
  contextRegionId     String?
  contextEventId      String?
  title         String
  createdAt     DateTime    @default(now())
  createdById   String
  isReadOnly    Boolean     @default(false)
  latestSummaryId String?

  createdBy     User        @relation("ThreadCreator", fields: [createdById], references: [id])
  messages      Message[]
}

model Message {
  id           String    @id @default(cuid())
  threadId     String
  authorId     String
  body         String
  createdAt    DateTime  @default(now())
  editedAt     DateTime?
  instrumentIds String?
  regionIds     String?
  eventIds      String?

  thread       Thread    @relation(fields: [threadId], references: [id])
  author       User      @relation(fields: [authorId], references: [id])
  instrument   Instrument? @relation(fields: [instrumentIds], references: [id])
}

model Watchlist {
  id           String        @id @default(cuid())
  name         String
  userId       String
  createdAt    DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id])
  instruments  Instrument[]
}

model Note {
  id            String    @id @default(cuid())
  body          String
  regionCode    String?
  instrumentId  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model LayoutConfig {
  id        String   @id @default(cuid())
  name      String
  config    String
  createdAt DateTime @default(now())
}
